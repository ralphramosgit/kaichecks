# Copy this file to .env.local and fill in your values.
# See resources/aws-setup-guide.md for where to get each key.

# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# FastAPI backend URL.
# Local dev (Docker running): http://localhost:8000
# AWS (ALB):                  http://YOUR_ALB_DNS_NAME_HERE
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────
# AWS (fill in after setup guide)
# ─────────────────────────────────────────────

# Your Amplify frontend URL (after Step 6 of the setup guide)
# NEXT_PUBLIC_AMPLIFY_URL=https://YOUR_AMPLIFY_URL_HERE

# AWS region used for all services
# NEXT_PUBLIC_AWS_REGION=us-east-1
